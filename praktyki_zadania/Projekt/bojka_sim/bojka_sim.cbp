				<Option compiler="gcc" />
				<Option parameters="127.0.0.1 8080 10" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
				<Linker>
					<Add library="ws2_32" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/bojka_sim" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
		</Compiler>
		<Unit filename="Generator.h" />
